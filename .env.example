# Application
APP_NAME=AI Chatbot Assistant
APP_ENV=development
SECRET_KEY=change-me-in-production-use-a-secure-random-key
DEBUG=True
HOST=0.0.0.0
PORT=5000
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///database/chatbot.db

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
OPENAI_SYSTEM_PROMPT=You are a helpful, professional AI assistant.

# Rate limiting
RATE_LIMIT_DEFAULT=100 per hour
RATE_LIMIT_CHAT=20 per minute

# CORS
CORS_ORIGINS=http://localhost:5000,http://localhost:3000

# Deployment
BASE_URL=http://localhost:5000
